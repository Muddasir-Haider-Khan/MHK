{
    "version": 2,
    "builds": [
        {
            "src": "api/index.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "api/index.js"
        },
        {
            "src": "/uploads/(.*)",
            "dest": "api/index.js"
        },
        {
            "src": "/admin",
            "dest": "/admin/index.html"
        },
        {
            "src": "/admin/(.*)",
            "dest": "/admin/index.html"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ],
    "cleanUrls": true
}